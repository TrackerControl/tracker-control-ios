# Web server that exposes /queue, /ping, /uploadAnalysis, and /reportAnalysisFailure.
SERVER=https://your-railway-app.example

# Must match UPLOAD_PASSWORD on the web server.
UPLOAD_PASSWORD=change-me

# Current analyser format.
ANALYSIS_VERSION=4
ANALYSIS_MODE=trackerscan

# SSH command run on the analyser host. The app bundle id is appended as argv[1].
TRACKERSCAN_CMD="ssh iphone trackerscan"
TRACKERSCAN_SIGNATURES=/var/mobile/ios_signatures_v2.json
TRACKERSCAN_SIGNATURE_SET=ios-v2

# Optional ipatool relogin credentials. Prefer logging in once with ipatool auth login.
APPLE_EMAIL=
APPLE_PASS=
IPATOOL_KEYCHAIN_PASSPHRASE=
# processQueue.sh passes this to ipatool as --keychain-passphrase.
PASS=$IPATOOL_KEYCHAIN_PASSPHRASE

# Safety limits.
MAX_DOWNLOAD_ATTEMPTS=2
MAX_DAILY_DOWNLOAD_BYTES=50000000000
MAX_APP_SIZE_BYTES=3000000000
MAX_ATTEMPT_DOWNLOAD_BYTES=3000000000
CONSECUTIVE_FAILURE_LIMIT=5
CIRCUIT_BREAKER_SLEEP=3600
DOWNLOAD_WATCHDOG_INTERVAL=5
NETWORK_INTERFACE=

# Runtime behavior.
RUN_ONCE=0
LIVE_LOG=1
